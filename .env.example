# Connect to Postgres via the shared transaction-mode pooler (app runtime, IPv4-only)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST].pooler.supabase.com:5432/postgres"

# Supabase project URL + publishable (browser-safe) key.
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Secret key — server-only, NEVER expose to the client.
SUPABASE_SECRET_KEY=sb_secret_your-key

# Email of an existing account to own the sample data from `npm run db:seed`.
SEED_USER_EMAIL=me@example.com
